# Telegram
TELEGRAM_BOT_TOKEN=replace_with_rotated_bot_token
ADMIN_CHAT_ID=replace_with_owner_chat_id
ALLOWED_CHAT_IDS=replace_with_owner_chat_id

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_rotated_service_role_key

# Mail provider adapter
# The provider endpoint/schema was not included, so configure it here.
MAIL_API_BASE_URL=https://v1.boomlify.com
MAIL_API_KEY=replace_with_rotated_mail_api_key
MAIL_API_AUTH_HEADER=X-API-Key
MAIL_API_MAILBOX_TOKEN_HEADER=X-Mailbox-Token
MAIL_API_CREATE_PATH=/api/v1/emails/create
MAIL_API_INBOX_PATH=/api/v1/emails/{mailbox_id}/messages
# Optional Boomlify lifetime: 10min, 1hour, 1day, or permanent.
MAIL_API_EMAIL_TIME=1day
MAIL_API_INCLUDE_DASHBOARD=true
# Optional. If omitted, the provider must return address/email in its create response.
MAIL_DEFAULT_DOMAIN=

LOG_LEVEL=INFO
